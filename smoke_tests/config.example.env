# Riley smoke harness config
# Copy to smoke_tests/.env and fill values.

# Required
SMOKE_BASE_URL=https://riley-api-786327046070.us-west1.run.app
SMOKE_ADMIN_TOKEN=
SMOKE_TENANT_ID=

# Optional (defaults to SMOKE_ADMIN_TOKEN where relevant)
SMOKE_USER_TOKEN=
SMOKE_NON_ADMIN_TOKEN=

# Optional access-request mutation flow
SMOKE_REQUESTER_TOKEN=
SMOKE_LEAD_TOKEN=

# Optional asset toggle mutation flow
SMOKE_ASSET_FILE_ID=

# Optional tuning
SMOKE_CHAT_QUERY=Smoke test: confirm Riley is responsive.
SMOKE_TIMEOUT_SECONDS=45

# Mutation tests are disabled by default for safety.
# Set true only in controlled environments where side-effects are expected.
SMOKE_ENABLE_MUTATION=false
